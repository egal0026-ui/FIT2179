{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": 500,
  "height": 300,

  "data": {
        "url": "Data/HouseSeats.csv"}
  
  ,
  "transform": [
    {
    "lookup": "DivisionNm",
    "from": {
        "data": {
      "url": "data/AUS_ELB_region.json",
      "format": {
        "type": "topojson",
        "feature": "AUS_ELB_region"
    }
  },
      "key": "properties.Elect_div"
      
    }, "as": "geo"
  },{
    "filter": "datum.ElectYear == '2025'"
  }],
  
  "projection": {
    "type": "equalEarth", "rotate": [-150, 0,0]
  },
  "mark": "geoshape",
  "encoding": {
    "shape": {
      "field":"geo",
      "type": "geojson"
    },
    "color": {
      "field": "PartyAb",
      "type": "nominal"
    },
  "tooltip": [
    {"field": "DivisionNm", "type": "nominal"},
    {"field": "PartyAb", "type": "nominal"}
  ]
  }
}
