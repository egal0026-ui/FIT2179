{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": "Most Seats held by each Party that has won seats in the Senate",
  "height": 600,
  "width": 400,
  "config": {
    "background": "aliceblue"
  },
  "data": {
    "url": "Data/Parties.csv"
  },
  "transform": [{
    "filter": "datum.SenSeats > 0"
  }],
  "mark": "bar",
  "encoding": {
    "x": {"field": "SenSeats", "type": "quantitative", "title": "Most seats held by party"},
    "y": {"field": "PartyNm", "type": "nominal", "title": "Party", "sort": "-x"},
    "tooltip": [
        {"field": "SenSeats", "type": "quantitative"},
        {"field": "SenYear", "type": "ordinal"}
    ]
  }
}