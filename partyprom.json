{
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "description": "Party prominence",
  "height": 600,
  "width": 400,



  "data": [
    {
        "name": "HouseSeatsByParty",
        "url": "Data/HouseSeatsByParty.csv",
        "format": {
            "type": "csv",
            "parse": {"Year": "number", "Elected": "number", "Party": "string"}
        } 
    },{
        "name": "HouseFiltered",
        "source": "HouseSeatsByParty",
        "transform": [
            {"type": "filter", "expr": "datum.Elected > 0"},
            {"type": "filter", "expr": "datum.Year == CurrentYear"},
            {"type": "window", 
            "sort": {"field": "Elected", "order": "descending"} }
        ]
    }
  ],

  "signals": [
    {
        "name": "sliderIndex",
        "value": 47,
        "bind": {"input": "range", "min": 0, "max": 47, "step": 1}
    },
    {
        "name": "CurrentYear",
        "value": 0,
        "update": "[1901,1903,1906,1910,1913,1914,1917,1919,1922,1925,1928,1929,1931,1934,1937,1940,1943,1946,1949,1951,1954,1955,1958,1961,1963,1966,1969,1972,1974,1975,1977,1980,1983,1984,1987,1990,1993,1996,1998,2001,2004,2007,2010,2013,2016,2019,2022,2025][sliderIndex]" 
    }
],



"scales": [
    {
      "name": "yscale",
      "type": "band",
      "domain": {
        "data": "HouseFiltered", "field": "PartyNm", 
        "sort": {"field":"Elected", "order": "descending"}
    },
      "range": "height",
      "padding": 0.05,
      "round": true
    },
    {
      "name": "xscale",
      "domain": {"data": "HouseFiltered", "field": "Elected"},
      "nice": true,
      "range": "width"
    },
    {
      "name": "color",
      "type": "ordinal",
      "domain": ["ALP", "LANG LAB", "ANTI-COM LAB",
      "PROT","LP","NAT","CP", "LNP", "NP", "CLP","LNQ","LCL","VFU","NAT & FARMERS",
      "UAP","FT","ANTI-SOC", 
      "GRN", "IND","XEN", "KAP", "PUP"],
      "range": ["#ef3b2c","#ef3b2c","#ef3b2c",
      "#0570b0","#0570b0","#0570b0","#0570b0","#0570b0","#0570b0","#0570b0","#0570b0","#0570b0","#0570b0","#0570b0",
      "#fec44f","#fec44f","#fec44f",
      "#328a1c","#787878", "#e37739","#70281a", "#d9c816"]
    }
  ],

  "axes": [
    { "orient": "bottom", "scale": "xscale" },
    { "orient": "left", "scale": "yscale" }
  ],

  "marks": [
    {
      "type": "rect",
      "from": {"data":"HouseFiltered"},
      "encode": {
        "update": {
          "x": {"scale": "xscale", "field": "Elected"},
          "x2": {"scale": "xscale", "value": 0},
          "y": {"scale": "yscale", "field": "PartyNm"},
          "height": {"scale": "yscale", "band": 1},
          "fill": {
            "field": "PartyAb",
            "type": "nominal",
            "scale": "color"
          }
          
        },
        "hover": {
          "fill": {"value": "red"}
        }
      }
    }]
}


 

  



 