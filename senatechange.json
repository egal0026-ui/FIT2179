{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "Stock prices of 5 Tech Companies over Time.",
  "width": "container",
  "height": 400,
  "config": {
    "background": "white",
    "axis": {
      "labelFont": "Verdana",
      "labelFontSize": 11,
      "labelFontWeight": "lighter",
      "titleFont": "Verdana",
      "titleFontSize": 14
    },
    "padding": 15,
    "lineBreak": "#"
  },
  "data": { "url": "Data/SenateSeatsByParty.csv" },

  "encoding": {
    "x": {
      "field": "Year",
      "type": "ordinal",
      "axis": { "labelAngle": 0 },
      "title": "Year"
    },
    "y": {
      "field": "Percentage Elected",
      "type": "quantitative",
      "title": "Percentage of Seats Elected",
      "axis": { "format": "%" }
    }
  },

  "layer": [
    {
      "mark": {
        "type": "line",
        "strokeDash": [3, 1]
      },
      "encoding": {
        "color": {
          "field": "Party",
          "type": "nominal",
          "scale": {
            "domain": [
              "Australian Labor Party",
              "Australian Motoring Enthusiasts",
              "Jacqui Lambie Network",
              "Pauline Hanson's One Nation",
              "Liberal-National Coalition",
              "Australian Sports Party",
              "Palmer United Australia Party",
              "Democratic Labour Party",
              "Family First Party",
              "David Pocock",
              "Derryn Hinch's Justice Party",
              "Centre Alliance",
              "Liberal Democratic Party",
              "Australian Greens",
              "Independent"
            ],
            "range": [
              "#e14645",
              "#0000ff",
              "#ffd520",
              "#ff6900",
              "#1c4f9c",
              "#0000ff",
              "#f8ef21",
              "#f44c01",
              "#1456f1",
              "#cf2c2b",
              "#002f5d",
              "#ff6300",
              "#60183c",
              "#10c25b",
              "#969696"
            ]
          },
          "legend": null
        },
        "tooltip": [
          { "field": "Party" },
          { "field": "Year" },
          { "field": "Seats Elected" },
          {
            "field": "Percentage Elected",
            "type": "quantitative",
            "format": ".2%"
          }
        ],
        "opacity": { "value": 0.6 }
      }
    },{
      "mark": {"type": "text", "dy": -30, "align": "left"},
      "encoding": {
        "text": {"field": "Annotation1"},
        "size": {"value": 10},
        "color": {"value": "#000"}
      }
    },{
      "mark": {"type": "text","dx": -75, "dy": 20, "align": "left"},
      "encoding": {
        "text": {"field": "Annotation2"},
        "size": {"value": 10},
        "color": {"value": "#000"}
      }
    }
  ]
}
