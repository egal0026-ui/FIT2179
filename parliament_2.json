{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "title": "Timeline of Governing Parties in Australia and the Prime Minister 1901-2026",

  "height": 400,
  "width": 1200,
  "config": {
    "background": "aliceblue"
  },

    "encoding": {
        "x": {"title": "Year"},
        "y": {"title": "Party"}
    },

  "layer": [
    {
      "data": {
        "url": "Data/ElectionWinners.csv"
      },
      "mark": "bar",
      "encoding": {
        "y": {
          "field": "Party",
          "type": "nominal",
          "scale": {
            "domain": ["FT", "PROT", "ALP", "NAT", "UAP", "LIB", "CP"]
          }
        },
        "x": { "field": "StartYear", "type": "temporal" },
        "x2": { "field": "EndYear" },
        "color": {
          "type": "ordinal",
          "field": "Party",
          "scale": {
            "domain": ["PROT", "ALP", "LIB", "NAT", "CP", "UAP", "FT"],
            "range": [
              "#74a9cf",
              "#ef3b2c",
              "#0570b0",
              "#386cb0",
              "#7fc97f",
              "#fec44f",
              "#fed976"
            ]
          }
        },
        "strokeWidth": { "value": 0.5 },
        "stroke": { "value": "#000" },
        "tooltip": [{ "field": "Party", "type": "nominal" }]
      }
    },{
       "data": {
        "url": "Data/PrimeMinisters.csv"
      }, 
      "mark": "circle",
      "encoding": {
        "y": {
          "field": "Party",
          "type": "nominal",
          "scale": {
            "domain": ["FT", "PROT", "ALP", "NAT", "UAP", "LIB", "CP"]
          }
        },
        "x": { "field": "StartDate", "type": "temporal" },
        "size": {"value": 100},
        "color": {
          "type": "ordinal",
          "field": "Party",
          "scale": {
            "domain": ["PROT", "ALP", "LIB", "NAT", "CP", "UAP", "FT"],
            "range": [
              "#74a9cf",
              "#ef3b2c",
              "#0570b0",
              "#386cb0",
              "#7fc97f",
              "#fec44f",
              "#fed976"
            ]
          },
          "legend": null
        },
        "strokeWidth": { "value": 0.5 },
        "stroke": { "value": "#000" },
        "tooltip": [{ "field": "Party", "type": "nominal" },
    {"field": "Surname", "type": "nominal"}]
      }
    }
  ]
}
