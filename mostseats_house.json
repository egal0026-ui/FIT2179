{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "height": 400,
  "width": "container",
  "padding": {"left": 30, "right": 30, "top": 30, "bottom": 30},
  "config": {
    "background": "white",
    "style": {
      "cell":{
        "stroke": "transparent"
      }
    },
      "axis": {
        "labelFont": "Verdana",
        "labelFontSize": 11,
        "labelFontWeight": "lighter",
        "titleFont": "Verdana",
        "titleFontSize": 14
      },
      "lineBreak": "#"
  },
  "data": {
    "url": "Data/Parties.csv"
  },
  "transform": [{
    "filter": "datum.HouseSeats > 0"
  }],

  "encoding": {
       "x": {"field": "HouseYear", "type": "temporal", "title": "Year", "axis": {"labelAngle": 0, "grid": false}},
    "y": {"field": "HousePercent", "type": "quantitative", "title": "Percentage of Seats", "axis": {"labelAngle": 0, "grid": false, "format": "%", "tickMinStep": 0.1 }, "scale": {"domain": [0,1]}}
  },

  "layer": [
    {  "mark": "circle",
  "encoding": {
     "size": {"value": 100},
    "opacity": {"value": 0.8},
    "tooltip": [
        {"field": "HouseSeats", "type": "quantitative", "title": "Seats Elected"},
        {"field": "HousePercent", "type": "quantitative", "format": ".2%", "title": "Seat Percentage"},
        {"field": "HouseYear", "type": "temporal", "format": "%Y", "title": "Year"},
        {"field": "PartyNm", "type": "nominal", "title": "Party"}
    ],
    "color": {
          "type": "ordinal",
          "field": "PartyColour",
          "scale": {
        "domain": [
          "Australian Labor Party","Australian Motoring Enthusiasts","Jacqui Lambie Network","Pauline Hanson's One Nation", "Liberal-National Coalition",
          "Anti Communist Labor Party","Australian Sports Party","Palmer United Australia Party","Democratic Labour Party","United Australia Party",
          "Lang Labor Party","Family First Party","Free Trade / Anti-Socialist Party","Katter's Australian Party","Nationalist Party",
          "David Pocock", "Derryn Hinch's Justice Party", "Centre Alliance","Liberal Democratic Party", "Protectionist Party",
          "Australian Greens","Independent"
        ],
        "range": [
          "#e14645","#0000ff","#ffd520","#ff6900","#1c4f9c",
          "#e14645","#0000ff","#f8ef21","#f44c01","#2596be",
          "#e14645","#1456f1","#ffd520","#b50204","#6495ed",
          "#cf2c2b","#002f5d","#ff6300","#60183c","#5590cc",
          "#10c25b","#969696"
        ]
          },
          "legend": null
        }
  }},{
    "mark": {"type": "text", "align": "left", "dx": -10, "dy": -50},
    "encoding": {
      "text" : {"field": "HouseAnnotation", "type": "nominal"},
      "color": {"value": "#000"},
      "size": {"value": 10}
    }
  },{
    "mark": {"type": "text", "align": "right", "dx": 10, "dy": -30},
    "encoding": {
      "text" : {"field": "Annotation", "type": "nominal"},
      "color": {"value": "#000"},
      "size": {"value": 10}
    }
  }
  ]
}