{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "height": 600,
  "width": "container",
      "config": {
    "background": "white",
    "style": {
      "cell": {
        "stroke": "transparent"
      },
      "axis": {
        "labelFont": "Verdana",
        "labelFontSize": 11,
        "labelFontWeight": "lighter",
        "titleFont": "Verdana",
        "titleFontSize": 14
      }
    },
    "lineBreak": "#"
  },
  "params": [
    {
      "name": "zoom_level",
      "value": 1000,
      "bind": {
        "input": "range",
        "min": 1000,
        "max": 10000,
        "step": 100,
        "name": "Zoom into Map: "
      }
    }
  ],
  "layer": [{
      "projection": {
        "type": "equirectangular",
        "center": [131, -13],
        "scale": {"expr": "zoom_level"}
      },
      "data": {
        "url": "Data/AUS_ELB_region.json",
        "format": { "type": "topojson", "feature": "AUS_ELB_region" }
      },
      "transform": [
        {
          "lookup": "properties.Elect_div",
          "from": {
            "data": {
              "url": "Data/HouseSeats2025.csv"
            },
            "key": "Electoral Division",
            "fields": ["State", "Electoral Division", "Party", "ElectYear"]
          }
        },
        {
          "filter": "datum.State != 'Northern Territory'"
        }
      ],

      "mark": { "type": "geoshape" },
      "encoding": {
        "color": {
          "condition": {
            "param": "zoom_level",
            "value": "#404040"
          },
          "legend": null
        },

        "opacity": {
          "value": 0.8
        },
        "strokeWidth": {
          "value": 0.25
        },
        "stroke": { "value": "#fff" }
      }
    },
    {
      "projection": {
        "type": "equirectangular",
        "center": [131, -13],
        "scale": {"expr": "zoom_level"}
      },
      "data": {
        "url": "Data/AUS_ELB_region.json",
        "format": { "type": "topojson", "feature": "AUS_ELB_region" }
      },
      "transform": [
        {
          "lookup": "properties.Elect_div",
          "from": {
            "data": {
              "url": "Data/HouseSeats2025.csv"
            },
            "key": "Electoral Division",
            "fields": ["State", "Electoral Division", "Party", "ElectYear"]
          }
        },
        {
          "filter": "datum.State == 'Northern Territory'"
        }
      ],
      "mark": { "type": "geoshape" },
      "encoding": {
        "fill": {
          "field": "Party",
          "type": "nominal",
          "scale": {
      "range": ["#e14645"],
      "domain": [
              "Australian Labor Party"
            ]
          },
          "legend": null
        },
        "stroke": { "value": "#000" },
        "tooltip": [
          { "field": "Party", "type": "nominal" },
          { "field": "Electoral Division", "type": "nominal" },
          { "field": "State", "type": "nominal" }
        ]
      }
    },{
      "data": { "url": "Data/HouseSeats2025.csv" },
      "transform": [
        { "filter": "datum.State == 'Northern Territory'" },
        { "filter": "datum.Display == '1'" }
      ],
      "mark": { "type": "rect" },
      "encoding": {
        "size": { "value": 11 },
        "color": { "value": "#fee7e3" },
        "x": { "value": 25 },
        "x2": { "value": 275 },
        "y": { "value": 50 },
        "y2": { "value": 200 }
      }
    },
    {
      "data": { "url": "Data/HouseSeats2025.csv" },
      "transform": [
        { "filter": "datum.State == 'Northern Territory'" },
        { "filter": "datum.Display == '1'" }
      ],
      "mark": { "type": "text" },
      "encoding": {
        "text": { "field": "Text" },
        "size": { "value": 12 },
        "color": { "value": "#000" },
        "x": { "value": 150 },
        "y": { "value": 137.5 }
      }
    },
    {
      "data": { "url": "Data/HouseSeats2025.csv" },
      "transform": [
        { "filter": "datum.State == 'Northern Territory'" },
        { "filter": "datum.Display == '1'" }
      ],
      "mark": { "type": "text" },
      "encoding": {
        "text": { "field": "Numbers"},
        "size": { "value": 36 },
        "color": { "value": "#e14645" },
        "stroke": {"value": "#e14645"},
        "x": { "value": 150 },
        "y": { "value": 100 }
      }
    }
  ]
}
