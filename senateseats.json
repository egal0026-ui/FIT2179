          { "field": "State" }
        ]
      }
    },
    {
      "data": {
        "url": "Data/SenateSeats.csv"
      },
      "transform": [{ "filter": "datum.State == 'South Australia'" }],

      "mark": "arc",
      "encoding": {
        "radius": { "value": 25 },
        "theta": { "field": "Percentage", "type": "quantitative" },
        "color": { "field": "PartyNm", "type": "nominal" },
        "latitude": { "field": "Lat", "type": "quantitative" },
