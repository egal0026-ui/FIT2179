      "mark": "arc",
      "encoding": {
        "radius": { "value": 25 },
        "theta": { "field": "Percentage", "type": "quantitative" },
        "color": { "field": "PartyNm", "type": "nominal" , 
          "legend": {
            "orient": "bottom",
            "title": "Political Parties",
            "labelFont": "Verdana",
            "labelFontSize": 11,
            "labelFontWeight": "lighter",
            "titleFont": "Verdana",
            "titleFontSize": 14,
            "columns": 5,
            "labelLimit": 250
          },
        "scale": {
        "domain": [
          "Australian Labor Party","David Pocock","Pauline Hanson's One Nation", "Liberal Party",   "Country Liberal Party",
          "Australian Greens","Jacqui Lambie Network","Palmer United Australia Party","The Nationals","Liberal National Party of Queensland"
        ],
        "range": [
          "#e14645","#cf2c2b","#ff6900","#1c4f9c","#1c4f9c",
          "#10c25b","#ffd520","#f8ef21","#1c4f9c","#1c4f9c"
        ]
      }},
        "latitude": { "field": "Lat", "type": "quantitative" },
        "longitude": { "field": "Long", "type": "quantitative" },
        "stroke": {"value": "#000"},
        "tooltip": [
          { "field": "Seats" },
          { "field": "PartyNm" },
          { "field": "State" }
        ]
      }
    }
  ]
}
