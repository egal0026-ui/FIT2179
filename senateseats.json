  "height": 500,
  "width": "container",
  "config": {
    "background": "white",

  "style": {
    "cell": {
      "stroke": "transparent"
    }
  
},
"padding": 15,
"lineBreak": "#"
  },
  
  "projection": {
    "type": "equirectangular",
    "center": [135, -26],
    "scale": 600
  },
