    "url": "Data/STE_2021_AUST_GDA2020.json",
    "format": { "type": "topojson", "feature": "STE_2021_AUST_GDA2020" }
  },

  "transform": [
    {
      "lookup": "properties.STE_NAME21",
      "from": {
        "data": {
          "url": "Data/SenateSeats.csv"
        },
        "key": "State",
        "fields": ["State", "PartyAb", "PartyNm", "Seats", "Lat", "Long"]
      }
    }
  ],

  "layer": [
    {
      "params": [
        {
          "name": "senate_selector",
          "select": { "type": "point", "fields": ["State"], "on": "click" }
        }
      ],

      "mark": { "type": "geoshape" },
      "encoding": {
        "fill": { "value": "#616161" },
        "tooltip": [{ "field": "State", "type": "nominal" }],
        "opacity": {
          "condition": {
            "param": "senate_selector",
            "value": 1
          },
          "value": 0.8
        },
        "strokeWidth": {
          "value": 1
        },
        "stroke": { "value": "#000" }
      }
    },{
        "mark":"rect",
        "encoding": {
            "x": {"value": 673},
            "x2": {"value":770},
            "y": {"value": 350},
            "y2": {"value": 352},
            "color": {"value": "#000"}
        }
